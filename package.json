{
  "name": "n8n-nodes-backupradar",
  "version": "1.0.0",
  "description": "BackupRadar integration for n8n community node.",
  "author": "Max Soukhomlinov <maxs@intellectit.com.au>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msoukhomlinov/n8n-nodes-backupradar.git"
  },
  "bugs": {
    "url": "https://github.com/msoukhomlinov/n8n-nodes-backupradar/issues"
  },
  "homepage": "https://github.com/msoukhomlinov/n8n-nodes-backupradar#readme",
  "keywords": [
    "n8n",
    "n8n-community-node",
    "n8n-community-node-package",
    "workflow",
    "integration"
  ],
  "engines": {
    "node": ">=20.15"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.build.json && npm run copy-icons",
    "copy-icons": "node -e \"require('fs').cpSync('src/nodes/BackupRadar/backupradar.svg', 'dist/nodes/BackupRadar/backupradar.svg')\"",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "n8n-core": "^1.41.0",
    "n8n-workflow": "^1.41.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/BackupRadarApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/BackupRadar/BackupRadar.node.js"
    ]
  }
}
